# Restore — required environment variables.
# Copy to .env and fill in real values. Never commit .env.

# --- Claude API (advisor) ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# --- Google Calendar (calendar_client) ---
# LOCAL dev: point at the OAuth *client secrets* JSON downloaded from Google
# Cloud Console (Desktop app OAuth client), then run `python scripts/authorize.py`
# once to mint token.json. Write scope is included for the stretch feature.
GOOGLE_CREDENTIALS_PATH=./google_credentials.json
GOOGLE_TOKEN_PATH=./token.json
GOOGLE_CALENDAR_ID=primary
#
# DEPLOYMENT: skip the files entirely — inject these three instead. authorize.py
# prints them at the end of the local run. If GOOGLE_REFRESH_TOKEN is set, the
# app builds credentials from env and never touches token.json.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Stretch: when true, /wake writes a "🌿 Restore" recovery block into the
# calendar on poor-sleep mornings. Default false so the demo stays read-only.
CALENDAR_WRITE_ENABLED=false

# --- Companion persona (one place; read by the brief AND chat replies) ---
COMPANION_NAME=Sprout
COMPANION_EMOJI=🌿🌙💛
COMPANION_PLAYFULNESS=3          # 1 = calm & gentle ... 5 = bubbly & playful
COMPANION_TELEGRAM_USERNAME=     # bot username (no @) for the "💬 chat" link on GET /

# --- Delivery channel ---
# Where the morning brief is sent: telegram | ntfy | both. Telegram is the
# primary chat-companion channel; keep ntfy as a demo fallback.
PUSH_CHANNEL=telegram

# --- Demo controls ---
# Gate the /reset command so it can't re-prime demo state in real life.
DEMO_MODE=false

# --- Telegram bot (telegram_client) ---
# From @BotFather (/newbot) and .../getUpdates. See README for the full walkthrough.
TELEGRAM_BOT_TOKEN=8123456789:AA...your-bot-token...
TELEGRAM_CHAT_ID=123456789
# Secret shared with Telegram for the conversational webhook (POST /telegram).
# Register it with scripts/set_telegram_webhook.py; the server checks it on every
# call via the X-Telegram-Bot-Api-Secret-Token header. Use a long random value.
TELEGRAM_WEBHOOK_SECRET=change-me-to-something-long-and-random

# --- ntfy push (notify) — fallback channel ---
# The topic name is the ONLY access control on ntfy.sh — anyone who knows it can
# read your pushes. Use a long, random, unguessable name (not "restore-annie").
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=restore-annie-x7k2p9

# --- Webhook auth ---
# /wake requires `Authorization: Bearer <WEBHOOK_SECRET>` when this is set.
# Leave unset only for local testing. Use a long random value in production.
WEBHOOK_SECRET=change-me-to-something-long-and-random
